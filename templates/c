<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>COPAR - Meus Dados</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: #ecf0f1;
            padding: 20px;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        
        /* Cabeçalho */
        .header {
            background: #2c3e50;
            color: white;
            padding: 20px;
            border-radius: 10px 10px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .header h1 {
            font-size: 24px;
        }
        
        .header a {
            background: #e74c3c;
            color: white;
            padding: 8px 15px;
            text-decoration: none;
            border-radius: 5px;
            font-size: 14px;
        }
        
        /* Cards de valores */
        .cards {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }
        
        .card {
            background: white;
            flex: 1;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .card .label {
            color: #7f8c8d;
            font-size: 14px;
            margin-bottom: 10px;
        }
        
        .card .valor {
            font-size: 28px;
            font-weight: bold;
            color: #2c3e50;
        }
        
        .card.receber .valor {
            color: #27ae60;
        }
        
        .card.recebido .valor {
            color: #3498db;
        }
        
        /* Seções */
        .secao {
            background: white;
            border-radius: 10px;
            margin-bottom: 20px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .secao h2 {
            background: #3498db;
            color: white;
            padding: 12px 20px;
            font-size: 18px;
        }
        
        /* Listas */
        .lista {
            padding: 15px;
        }
        
        .item {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }
        
        .item:last-child {
            border-bottom: none;
        }
        
        .item-estoque {
            font-size: 16px;
        }
        
        .item-estoque strong {
            color: #2c3e50;
        }
        
        .item-venda {
            font-size: 14px;
            color: #555;
        }
        
        .item-venda .data {
            color: #7f8c8d;
            font-size: 12px;
        }
        
        .vazio {
            padding: 30px;
            text-align: center;
            color: #95a5a6;
        }
        
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 3px;
            font-size: 11px;
            margin-left: 10px;
        }
        
        .badge.pago {
            background: #27ae60;
            color: white;
        }
        
        .badge.pendente {
            background: #e74c3c;
            color: white;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            color: #7f8c8d;
            font-size: 12px;
        }
        
        @media (max-width: 600px) {
            .cards {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Cabeçalho -->
        <div class="header">
            <h1>🌾 COPAR</h1>
            <div>
                Olá, <strong>{{ nome }}</strong>
                <a href="/logout">Sair</a>
            </div>
        </div>
        
        <!-- Cards de valores -->
        <div class="cards">
            <div class="card receber">
                <div class="label">💰 A RECEBER</div>
                <div class="valor">R$ {{ "%.2f"|format(total_a_receber) }}</div>
            </div>
            <div class="card recebido">
                <div class="label">✅ JÁ RECEBIDO</div>
                <div class="valor">R$ {{ "%.2f"|format(total_recebido) }}</div>
            </div>
        </div>
        
        <!-- Estoque Atual -->
        <div class="secao">
            <h2>📦 SEU ESTOQUE ATUAL</h2>
            <div class="lista">
                {% if estoque %}
                    {% for item in estoque %}
                    <div class="item item-estoque">
                        <strong>{{ item.peso|round(1) }} kg</strong> de {{ item.tipo }} {{ item.classe }}
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="vazio">Você não tem produtos em estoque no momento.</div>
                {% endif %}
            </div>
        </div>
        
        <!-- Histórico de Vendas -->
        <div class="secao">
            <h2>📋 VENDAS REALIZADAS</h2>
            <div class="lista">
                {% if vendas %}
                    {% for venda in vendas %}
                    <div class="item item-venda">
                        <strong>{{ venda.peso|round(1) }} kg</strong> de {{ venda.tipo }} {{ venda.classe }}
                        <span class="data">- {{ venda.data }}</span>
                        {% if venda.status == 'Pago' %}
                            <span class="badge pago">Pago</span>
                        {% else %}
                            <span class="badge pendente">R$ {{ "%.2f"|format(venda.saldo) }} a receber</span>
                        {% endif %}
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="vazio">Nenhuma venda registrada ainda.</div>
                {% endif %}
            </div>
        </div>
        
        <div class="footer">
            Sistema COPAR - Gestão de Alho
        </div>
    </div>
</body>
</html>
